[Unit]
Description=Load qps615.ko module
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/sbin/modprobe tc956x_pcie_eth tc956x_eth_ports_bdf=0x500,0x501 macX_interface=4,4 portX_mdc=8,8 portX_c45_state=0,0 pcie_link_speed=1

[Install]
WantedBy=multi-user.target
